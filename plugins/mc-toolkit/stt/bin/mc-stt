#!/opt/homebrew/bin/python3.14
"""mc-stt — shared local-first speech-to-text CLI.

One transcription tool for every caller (voicememos, summarize, whatsapp, …) so the
model choice, VAD-windowing, and hallucination filter live in ONE place. The shebang
pins the interpreter that has mlx-whisper, so callers in other Python envs just shell
out to `mc-stt` and get the right runtime for free.

  mc-stt <audio> [--engine local|openai|openai-mini|openai-diarize|elevenlabs|assemblyai]
                 [--language pl|en|auto]   # default auto
                 [--format text|json]      # text (default) | json {words,text,language}
                 [--model <override>]

--format json returns the AssemblyAI-shaped contract diarization consumes:
  {"words":[{text,start,end(ms),speaker,confidence}], "text", "language"}.
Only `local` produces word timestamps today.
"""
import argparse
import json
import os
import sys

# realpath (not abspath): when invoked via the ~/.local/bin symlink, abspath would
# point at the symlink dir and miss engines/. realpath resolves to the real bin/.
HERE = os.path.dirname(os.path.realpath(__file__))
ENGINES = os.path.join(os.path.dirname(HERE), "engines")
sys.path.insert(0, ENGINES)


def env(key, default=None):
    """Resolve a setting: env var → ~/.claude/.env → default. (Self-contained — mc-stt
    is shared infra, so it doesn't import any one skill's config layer.)"""
    v = os.environ.get(key)
    if v is not None:
        return v
    try:
        for line in open(os.path.expanduser("~/.claude/.env")):
            line = line.strip()
            if line and not line.startswith("#") and line.startswith(key + "="):
                return line.split("=", 1)[1].strip().strip('"').strip("'")
    except OSError:
        pass
    return default


def run_local(audio, language, model, fmt):
    import local
    res = local.transcribe(audio, language=language, model=model)
    return res


def main():
    ap = argparse.ArgumentParser(prog="mc-stt", description="shared local-first STT")
    ap.add_argument("audio")
    ap.add_argument("--engine", default="local",
                    choices=["local", "openai", "openai-mini", "openai-diarize",
                             "elevenlabs", "assemblyai"])
    ap.add_argument("--language", default=env("MC_STT_LANG", "auto"),
                    help="2-letter code or 'auto' (default: auto)")
    ap.add_argument("--format", dest="fmt", default="text", choices=["text", "json"])
    ap.add_argument("--model", default=None, help="engine model override")
    args = ap.parse_args()

    if not os.path.exists(args.audio):
        sys.exit(f"mc-stt: audio not found: {args.audio}")

    if args.engine == "local":
        res = run_local(args.audio, args.language, args.model, args.fmt)
    else:
        sys.exit(f"mc-stt: engine '{args.engine}' not extracted yet — for now use "
                 f"voicememos/scripts/. Cloud engines land in build step 4.")

    if args.fmt == "json":
        sys.stdout.write(json.dumps(res, ensure_ascii=False) + "\n")
    else:
        sys.stdout.write((res.get("text") or "").strip() + "\n")


if __name__ == "__main__":
    main()
